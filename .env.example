# Gmail MCP Server Configuration

# OAuth configuration
OAUTH_PORT=8080

# SSE Server configuration
SSE_PORT=5553

# Write mode (send, reply, delete, archive, mark read/unread)
# Server starts read-only by default. Set to true to enable write operations.
ALLOW_WRITE=false

# REST API server (for the frontend)
API_PORT=8000

# Anthropic API configuration (for client testing)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL_NAME=claude-sonnet-4-6
